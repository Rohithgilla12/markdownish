{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markdownish",
  "version": "0.1.0",
  "identifier": "dev.gilla.markdownish",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Markdownish",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#1F1916"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "A personal markdown editor.",
      "args": [
        {
          "name": "path",
          "index": 1,
          "takesValue": true,
          "description": "A folder to open on launch."
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
